{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "candidate": {"type": "string"},
    "forbidden_claims_present": {"items": {"type": "string"}, "type": "array"},
    "m2_status": {"const": "DISABLED"},
    "not_run": {"items": {"type": "string"}, "type": "array"},
    "packet_digest": {"type": "string"},
    "schema_id": {"const": "GrokVerificationReport.v1"},
    "verdict": {"enum": ["PASS", "FAIL", "NOT_RUN"]}
  },
  "required": [
    "schema_id",
    "candidate",
    "verdict",
    "not_run",
    "m2_status",
    "forbidden_claims_present",
    "packet_digest"
  ],
  "type": "object"
}
