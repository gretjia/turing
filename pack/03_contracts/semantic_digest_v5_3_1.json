{
  "schema_id": "turingos.semantic_digest.v1",
  "status": "FROZEN_V5_3_1",
  "closes_blocker": "B1",
  "as_of": "2026-06-21",
  "revision": "rev3",
  "revision_note": "rev3 additionally separates the Git-minted event_id from the committed MicroEventEnvelope body and pins content_digest == payload_hash == sha256(JCS(payload)).",
  "root_law": "00_authority/constitution_root_law.md Art. 0.2",
  "depends_on": "turingos.jcs.v1 (restricted RFC 8785; floats forbidden; ASCII load-bearing keys; arrays order-preserving)",
  "problem": "A self-digest field D lives inside object O and is defined as a digest of O. Naive sha256(JCS(O)) is an unsatisfiable fixed point. Earlier packs had no unified exclusion rule across goal_digest / graph_hash / projection_hash / visible_card_hash.",
  "algorithm": {
    "name": "semantic_digest",
    "steps": [
      "1. sub = json_pointer_get(O, entry.target_pointer)   -- '' selects the whole object; '/payload' selects the sibling payload subtree",
      "2. sub = apply_canonical_sort(sub, entry.canonical_sort)   -- sort declared arrays by declared keys (JCS preserves array order, so order-independent digests MUST sort here)",
      "3. for ptr in entry.self_pointers: sub = json_pointer_delete(sub, ptr)   -- true nested JSON-Pointer; a non-resolving pointer raises, never a silent no-op",
      "4. exclusion = global.excluded_key_names UNION entry.extra_excluded_key_names; sub = recursively drop every dict key whose name is in exclusion",
      "5. digest = lowercase_hex(sha256(turingos.jcs.v1(sub)))",
      "6. determinism: no clock, no randomness, no environment read (the SG-10 cross-implementation oracle property)."
    ],
    "required_properties": {
      "P1_determinism": "same (O, entry) => same digest on re-run and across implementations",
      "P2_stability": "mutating only excluded fields (self-digest field, global names, or entry.extra_excluded_key_names) leaves the digest unchanged",
      "P3_sensitivity": "mutating any included (semantic) field changes the digest",
      "P4_fixed_point_resolution": "a self-digest field is always in its own self_pointers, so the digest is independent of its own value",
      "P_order": "for digests over a graph/array (graph_hash), permuting the canonical_sort arrays leaves the digest unchanged (achieves SG-71 node/edge order independence)",
      "P_target": "content_digest/payload_hash digest the sibling /payload subtree and equal the independently computed sha256(JCS(payload)); they are stable to envelope-level fields"
    }
  },
  "global": {
    "excluded_key_names": [
      "human_summary",
      "description",
      "label",
      "display",
      "x",
      "y",
      "layout",
      "elk",
      "localized"
    ],
    "rationale": "Non-semantic presentation / localization / graph-layout fields. Projection owns no truth, so they must never influence a sovereign digest.",
    "lint_rule": "No governed payload schema may use an excluded key as semantic data. check_semantic_digest_v5_3_1.py scans 03_contracts and 05_schemas."
  },
  "digest_fields": [
    {
      "field": "content_digest",
      "schema_id": "micro_event_envelope.v1",
      "self": false,
      "entry": {
        "target_pointer": "/payload",
        "self_pointers": []
      },
      "required_before_ref_move": true,
      "note": "Digests the SIBLING /payload subtree (target_pointer consumed by the helper); not inside the object it digests, so not a fixed point. Equals sha256(JCS(payload)) (P_target)."
    },
    {
      "field": "payload_hash",
      "schema_id": "micro_event_envelope.v1",
      "self": false,
      "entry": {
        "target_pointer": "/payload",
        "self_pointers": []
      },
      "required_before_ref_move": true,
      "note": "Append-envelope synonym of content_digest; identical mechanism and value."
    },
    {
      "field": "goal_digest",
      "schema_id": "goal_state.v1",
      "self": true,
      "entry": {
        "target_pointer": "",
        "self_pointers": [
          "/goal_digest"
        ]
      },
      "required_before_ref_move": true,
      "note": "Self-referential: excludes itself + global non-semantic keys."
    },
    {
      "field": "graph_hash",
      "schema_id": "work_graph.v1",
      "self": true,
      "entry": {
        "target_pointer": "",
        "self_pointers": [
          "/graph_hash"
        ],
        "canonical_sort": [
          {
            "array_pointer": "/nodes",
            "sort_keys": [
              "id"
            ]
          },
          {
            "array_pointer": "/edges",
            "sort_keys": [
              "src",
              "dst",
              "kind"
            ]
          }
        ]
      },
      "required_before_ref_move": true,
      "note": "Self-referential AND order-independent: nodes sorted by id, edges by (src,dst,kind) BEFORE canonicalization, with a TOTAL-ORDER tie-break on each element's full canonical bytes so duplicate ids / parallel edges cannot reintroduce order-dependence. Layout keys (x,y,label,layout,elk) are global-excluded, so graph_hash is layout-independent (SG-71)."
    },
    {
      "field": "projection_hash",
      "schema_id": "projection_view.v1",
      "self": true,
      "entry": {
        "target_pointer": "",
        "self_pointers": [
          "/projection_hash"
        ],
        "extra_excluded_key_names": [
          "cache_index",
          "built_at",
          "disposable_counter",
          "sqlite_path"
        ]
      },
      "required_before_ref_move": false,
      "note": "Self-referential. Cache/index/build-time fields excluded (scoped to this field, not global) so projection_hash reproduces after cache deletion (SG-72)."
    },
    {
      "field": "visible_card_hash",
      "schema_id": "approval_card.v1",
      "self": true,
      "entry": {
        "target_pointer": "",
        "self_pointers": [
          "/visible_card_hash"
        ],
        "extra_excluded_key_names": [
          "localized_chrome",
          "chrome",
          "explanation"
        ]
      },
      "required_before_ref_move": true,
      "note": "Self-referential. Localization/explanatory chrome excluded (global + scoped) so visible == hashed == signed == gate-consumed bytes (SG-59 four-byte identity)."
    }
  ],
  "not_self_digest_reference": {
    "note": "These digest fields summarize OTHER content (sibling file, foreign payload, external evidence) and are NOT fixed points; plain sha256(JCS(target)).",
    "fields": [
      "sampling_plan_digest",
      "implementation_digest",
      "evidence_digest",
      "pack_manifest_sha256",
      "canonical_spec_sha256",
      "constitution_sha256",
