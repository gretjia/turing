      "diff_hash",
      "tree_hash",
      "stdout_digest",
      "stderr_digest"
    ]
  },
  "forbidden": {
    "head_set_after": "An event can never embed its own Git OID. head_set_after is forbidden in every payload (HeadSet is derived mechanically post-mint).",
    "additional_self_digest": "A new self-digest field WITHOUT an entry here is an SG-81 failure (closed-world reject)."
  },
